#!/usr/bin/env bash
# Pick or create a dtach session, primarily for phone Termius use.
#
# Usage:
#   mobile-attach            # interactive menu
#   mobile-attach <name>     # attach to <name> if live, else create it
#
# Sweeps zombie sockets (server died but socket file lingers), then
# shows a numbered menu of live sessions sorted by mtime (newest
# first). Empty enter picks #1 — the one you most likely just
# detached from. `n` makes a new session, `q` exits.
#
# Whenever a name is supplied (CLI arg or via the `n` menu prompt),
# the script reports up front whether it is creating a new session or
# attaching to an existing one, so `dtach -A`'s silent reuse never
# surprises you.
#
# Override the socket directory with MOBILE_DTACH_DIR.

set -euo pipefail

DIR="${MOBILE_DTACH_DIR:-$HOME/.dtach}"
SHELL_CMD=("${SHELL:-/bin/bash}" -l)
mkdir -p "$DIR"

# Is the unix socket actually in LISTEN state with a server accept()ing
# behind it? `ss -lx` is the strictest check — a half-dead dtach that
# lost its child shell but didn't exit yet will hold the socket file
# (so fuser sees it) but not listen, which is exactly the stale case
# we want to treat as dead. Falls back to fuser / lsof if ss is
# missing, accepting the weaker guarantee there.
is_alive() {
  local sock="$1"
  if command -v ss >/dev/null 2>&1; then
    ss -lxH 2>/dev/null | awk -v s="$sock" '$5 == s { found=1 } END { exit !found }'
    return
  fi
  if command -v fuser >/dev/null 2>&1; then
    fuser "$sock" >/dev/null 2>&1
    return
  fi
  if command -v lsof >/dev/null 2>&1; then
    lsof -- "$sock" >/dev/null 2>&1
    return
  fi
  # No probe tool available — assume alive so we don't delete real
  # sessions on a stripped-down system.
  return 0
}

# Print live socket paths, newest mtime first. Removes dead socket
# files as a side effect so the menu stays clean.
sweep_and_list() {
  local s alive=()
  shopt -s nullglob
  for s in "$DIR"/*.sock; do
    if [[ -S "$s" ]] && is_alive "$s"; then
      alive+=("$s")
    else
      rm -f -- "$s" 2>/dev/null || true
    fi
  done
  shopt -u nullglob
  (( ${#alive[@]} == 0 )) && return 0
  ls -1t -- "${alive[@]}" 2>/dev/null
}

valid_name() {
  [[ "$1" =~ ^[A-Za-z0-9._-]+$ ]]
}

start_or_attach() {
  local name="$1"
  if ! valid_name "$name"; then
    printf 'name must match [A-Za-z0-9._-]+\n' >&2
    exit 1
  fi
  local sock="$DIR/${name}.sock"
  if [[ -S "$sock" ]] && is_alive "$sock"; then
    printf 'Session "%s" already exists, attaching.\n' "$name"
  else
    # Stale socket file from a previously-killed server; remove so
    # dtach -A can rebind cleanly.
    rm -f -- "$sock" 2>/dev/null || true
    printf 'Creating new session "%s".\n' "$name"
  fi
  # -r winch: on reattach send SIGWINCH so full-screen programs
  # (watch, top, htop, vim) redraw themselves. Ctrl-L (dtach's
  # default) misses watch in particular.
  exec dtach -A "$sock" -r winch -z -E "${SHELL_CMD[@]}"
}

prompt_new() {
  local n
  read -rp "Name for new session: " n
  start_or_attach "${n:-}"
}

# CLI shortcut: skip the menu, go straight to "create or attach <name>".
if (( $# > 0 )); then
  start_or_attach "$1"
fi

mapfile -t live < <(sweep_and_list)

if (( ${#live[@]} == 0 )); then
  printf 'No live dtach sessions in %s\n' "$DIR"
  read -rp "Name for new session [main]: " n
  start_or_attach "${n:-main}"
fi

printf '\nLive sessions in %s (newest first):\n' "$DIR"
for i in "${!live[@]}"; do
  base=$(basename -- "${live[i]}" .sock)
  ts=$(stat -c '%y' -- "${live[i]}" 2>/dev/null | cut -d. -f1)
  printf '  %2d) %-24s  %s\n' "$((i+1))" "$base" "${ts:-?}"
done
printf '   n) new session\n'
printf '   q) quit\n'

read -rp "Choose [1]: " pick
pick="${pick:-1}"

case "$pick" in
  q|Q)
    exit 0
    ;;
  n|N)
    prompt_new
    ;;
  *)
    if [[ "$pick" =~ ^[0-9]+$ ]] && (( pick >= 1 && pick <= ${#live[@]} )); then
      exec dtach -a "${live[$((pick-1))]}" -r winch -E
    fi
    printf 'invalid choice: %s\n' "$pick" >&2
    exit 1
    ;;
esac
